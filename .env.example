# Telegram Bot API token from @BotFather. Do not commit a real token.
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-token

# Public HTTPS URL of the deployed Telegram Mini App.
TELEGRAM_MINI_APP_URL=

# Text shown on the bot menu button.
TELEGRAM_MENU_TEXT=Party Games

# Optional: set a menu button only for one private chat.
# Leave empty to set the default menu button for all users.
TELEGRAM_CHAT_ID=

# Optional: override Expo web asset base path during export.
# Use /party-games for GitHub Pages project hosting, or / for a custom root domain.
EXPO_BASE_URL=/party-games
